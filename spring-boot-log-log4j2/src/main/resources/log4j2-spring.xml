<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" packages="">
    <Properties>
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n</Property>
        <Property name="LOG_HOME">logs</Property>
    </Properties>

    <Appenders>
        <!-- 定义 RoutingAppender -->
        <Routing name="DeviceRoutingAppender">
            <Routes pattern="${ctx:deviceId}"> <!-- ctx: 表示从 ThreadContext (MDC) 中获取 deviceId -->
                <!-- 默认路由 -->
                <Route key="unknown">
                    <RollingFile name="UnknownDeviceFile"
                                 fileName="${LOG_HOME}/device_unknown.log"
                                 filePattern="${LOG_HOME}/device_unknown-%d{yyyy-MM-dd}-%i.log.gz">
                        <PatternLayout pattern="${LOG_PATTERN}"/>
                        <Policies>
                            <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                            <SizeBasedTriggeringPolicy size="100 MB"/>
                        </Policies>
                    </RollingFile>
                </Route>
                <!-- 动态路由模板 -->
                <!-- 注意：这里没有写死具体的设备号，而是使用 ${ctx:deviceId} 作为占位符 -->
                <Route>
                    <RollingFile name="DeviceFile-${ctx:deviceId}"
                                 fileName="${LOG_HOME}/device_${ctx:deviceId}.log"
                                 filePattern="${LOG_HOME}/device_${ctx:deviceId}/device_${ctx:deviceId}-%d{yyyy-MM-dd}-%i.log.gz">
                        <PatternLayout pattern="${LOG_PATTERN}"/>
                        <Policies>
                            <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                            <SizeBasedTriggeringPolicy size="100 MB"/>
                        </Policies>
                    </RollingFile>
                </Route>
            </Routes>
        </Routing>

        <!-- 控制台输出，用于调试 -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>
    </Appenders>

    <Loggers>
        <!-- 专门用于设备日志的 Logger -->
        <Logger name="DeviceLogger" level="DEBUG" additivity="false">
            <AppenderRef ref="DeviceRoutingAppender"/>
        </Logger>

        <Root level="INFO">
            <AppenderRef ref="DeviceRoutingAppender"/>
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>